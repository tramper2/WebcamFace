<svg width="200" height="100" viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="clearGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f0f0;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#d0d0d0;stop-opacity:0.6" />
    </linearGradient>
  </defs>
  <!-- Left Frame -->
  <ellipse cx="50" cy="50" rx="38" ry="33" fill="none" stroke="url(#clearGradient)" stroke-width="5"/>
  <!-- Right Frame -->
  <ellipse cx="150" cy="50" rx="38" ry="33" fill="none" stroke="url(#clearGradient)" stroke-width="5"/>
  <!-- Bridge -->
  <path d="M 88 50 Q 100 47 112 50" fill="none" stroke="url(#clearGradient)" stroke-width="4"/>
  <!-- Left Temple -->
  <path d="M 12 42 L 0 38" fill="none" stroke="url(#clearGradient)" stroke-width="4"/>
  <!-- Right Temple -->
  <path d="M 188 42 L 200 38" fill="none" stroke="url(#clearGradient)" stroke-width="4"/>
</svg>