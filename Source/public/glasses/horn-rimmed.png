<svg width="200" height="100" viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="frameGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#2c1810;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a0f0a;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Left Frame -->
  <ellipse cx="50" cy="50" rx="40" ry="35" fill="none" stroke="url(#frameGradient)" stroke-width="8"/>
  <!-- Right Frame -->
  <ellipse cx="150" cy="50" rx="40" ry="35" fill="none" stroke="url(#frameGradient)" stroke-width="8"/>
  <!-- Bridge -->
  <path d="M 90 50 Q 100 45 110 50" fill="none" stroke="url(#frameGradient)" stroke-width="6"/>
  <!-- Left Temple -->
  <path d="M 10 40 L 0 35" fill="none" stroke="url(#frameGradient)" stroke-width="6"/>
  <!-- Right Temple -->
  <path d="M 190 40 L 200 35" fill="none" stroke="url(#frameGradient)" stroke-width="6"/>
</svg>